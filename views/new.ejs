<!DOCTYPE html>
<html lang="en">

<%- include("includes/head.ejs")%>


      <body>

            <div class="container">
                  <div class="card">

                        <h1 class="h1">Add New User Details</h1>

                        <form action="/user" method="post">
                              <input type="text" name="username" placeholder="enter new username" required><br><br>
                              <input type="email" name="email" pattern="^[a-zA-Z0-9._%+-]+@gmail\.com$"
                                    placeholder="enter your email" required><br><br>
                              <input type="password" name="password" placeholder="enter new user password"
                                    required><br><br>
                              <button type="submit">submit</button>
                        </form>
                  </div>
            </div>
      </body>

</html>